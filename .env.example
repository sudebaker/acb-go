# ACB configuration
ACB_PORT=8090
ACB_DB_PATH=/var/lib/acb/acb.db
# Use "redis:6379" with Docker bridge networking, "localhost:6379" with network_mode: host
ACB_REDIS_ADDR=redis:6379
ACB_REDIS_PASS=
# Use "rustfs:9000" with Docker bridge networking, "localhost:9000" with network_mode: host
ACB_RUSTFS_ENDPOINT=rustfs:9000
ACB_RUSTFS_BUCKET=acb-artifacts
ACB_LOG_LEVEL=info
ACB_ARTIFACT_TTL_DAYS=30
ACB_MAX_UPLOAD_SIZE_MB=32
# Set to "1" to allow http:// webhook URLs (for Docker/internal networks)
# Default: only https:// allowed (production)
ACB_ALLOW_HTTP_WEBHOOKS=1

# RustFS credentials (generate with: ./scripts/gen-env.sh)
RUSTFS_REGION=us-east-1
RUSTFS_ACCESS_KEY_ID=
RUSTFS_SECRET_ACCESS_KEY=
