# ACB configuration
ACB_PORT=8090

# PostgreSQL connection
ACB_PG_HOST=localhost
ACB_PG_PORT=5433
ACB_PG_USER=acb
ACB_PG_PASSWORD=acb-secure-pg-pass-2026
ACB_PG_DATABASE=acb

# Use "redis:6379" with Docker bridge networking, "localhost:6379" with network_mode: host
ACB_REDIS_ADDR=redis:6379
ACB_REDIS_PASS=
# Use "rustfs:9000" with Docker bridge networking, "localhost:9000" with network_mode: host
ACB_RUSTFS_ENDPOINT=rustfs:9000
ACB_RUSTFS_BUCKET=acb-artifacts
ACB_LOG_LEVEL=info
ACB_ARTIFACT_TTL_DAYS=30
ACB_MAX_UPLOAD_SIZE_MB=32
# Set to "1" to allow http:// webhook URLs (for Docker/internal networks)
# Default: only https:// allowed (production)
ACB_ALLOW_HTTP_WEBHOOKS=1

# Pending task timeout (minutes before unclaimed tasks auto-expire, default 15)
ACB_PENDING_TIMEOUT_MIN=15
# How often to check for expired tasks (seconds, default 60)
ACB_PENDING_TIMEOUT_CHECK_SEC=60

# Allowed skills catalog (comma-separated). Task creation and agent registration
# reject skills not in this list. Leave empty to allow any skill.
ACB_ALLOWED_SKILLS=go,python,java,rust,testing,devops,data

# Allowed tags catalog (comma-separated). Task creation rejects tags not in this list.
# Leave empty to allow any tag.
ACB_ALLOWED_TAGS=

# Webhook encryption key (base64-encoded, 32 bytes / 256-bit).
# Falls back to WEBHOOK_SECRET_KEY if not set.
ACB_WEBHOOK_SECRET_KEY=

# Webhook HMAC secret for signing outgoing webhooks.
WEBHOOK_SECRET_KEY=

# Admin token for bootstrap authentication.
# If not set, a random token is generated and logged on every restart.
ACB_ADMIN_TOKEN=

# RustFS credentials (generate with: ./scripts/gen-env.sh)
# ACB_RUSTFS_REGION is preferred; RUSTFS_REGION is kept as fallback.
ACB_RUSTFS_REGION=us-east-1
RUSTFS_REGION=us-east-1
RUSTFS_ACCESS_KEY_ID=
RUSTFS_SECRET_ACCESS_KEY=

# Agent tokens (generate with: scripts/gen-env.sh or ACB admin API)
ACB_AGENT_QUIQUE_TOKEN=
ACB_AGENT_BRAULIO_TOKEN=
ACB_AGENT_ARMANDO_TOKEN=

# Agent webhook secrets (used by poll/notify scripts)
ACB_AGENT_QUIQUE_WEBHOOK_SECRET=
ACB_AGENT_BRAULIO_WEBHOOK_SECRET=
ACB_AGENT_ARMANDO_WEBHOOK_SECRET=
